# ─────────────────────────────────────────────────────────────
# VerdictArena environment  —  copy this file to .env.local and fill in.
#
# The app runs in three modes, auto-detected from which vars are set
# (highest priority first):
#
#   1) BROKER mode  -> ZG_PRIVATE_KEY set    (TEE-verifiable inference, the real deal)
#   2) ROUTER mode  -> ZG_ROUTER_API_KEY set (real 0G Compute, no per-response TEE verify)
#   3) DEMO mode    -> nothing set           (mock verdict, UI runs without funds — clearly labelled)
#
# For the hackathon SUBMISSION use BROKER mode: the "verify this judgment"
# feature (the load-bearing, anti-bolt-on artifact) only works there.
# ─────────────────────────────────────────────────────────────

# --- BROKER mode (recommended for submission) ---------------------------------
# A funded 0G testnet wallet private key. Get test 0G from https://faucet.0g.ai
# Then run:  npm run setup:ledger 0.5   (deposits 0G into the compute ledger)
# NEVER commit a real key. This wallet only needs testnet funds.
ZG_PRIVATE_KEY=

# Optional: pin a specific TEE inference provider address.
# If unset, the app picks the first chatbot provider from listService().
ZG_PROVIDER=

# --- ROUTER mode (fastest first demo) -----------------------------------------
# OpenAI-compatible gateway key from https://pc.0g.ai
ZG_ROUTER_API_KEY=
ZG_ROUTER_URL=https://router-api.0g.ai/v1
# Model id served by the router (verify a valid one in the dashboard).
ZG_MODEL=

# --- Network (defaults are 0G Galileo testnet; verify chainId in your wallet) --
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_CHAIN_ID=16602
ZG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
ZG_EXPLORER_URL=https://chainscan-galileo.0g.ai
